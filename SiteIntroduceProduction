// Placeholder for Code Snippet Animation (using simple text reveal)
const CodeSnippet = ({ title, code }) => {
  const [displayedCode, setDisplayedCode] = useState('');
  React.useEffect(() => {
    setDisplayedCode(''); // Reset on title change
    const timer = setTimeout(() => {
      let i = 0;
      const intervalId = setInterval(() => {
        setDisplayedCode(code.substring(0, i + 1));
        i++;
        if (i === code.length) {
          clearInterval(intervalId);
        }
      }, 30); // Adjust speed here
      return () => clearInterval(intervalId);
    }, 500); // Delay start
    return () => clearTimeout(timer);
  }, [code]);

  return (
    <div>
      <p className="text-text-secondary mb-2">{title}</p>
      <pre className="bg-gray-800 p-4 rounded-md text-sm overflow-x-auto text-text-primary font-mono">
        <code>{displayedCode}</code>
      </pre>
    </div>
  );
};

